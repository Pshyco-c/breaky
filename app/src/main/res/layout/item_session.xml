<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeWidth="1dp"
    app:strokeColor="?colorSurfaceVariant"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Colored left accent bar -->
        <View
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="?colorPrimary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

        <!-- Top row: Subject name and action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Subject Name -->
            <TextView
                android:id="@+id/tvSubject"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mathematics"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="?colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Edit Button -->
            <ImageView
                android:id="@+id/btnEdit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Edit session"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                app:tint="?colorPrimary"
                android:layout_marginEnd="4dp" />

            <!-- Delete Button -->
            <ImageView
                android:id="@+id/btnDelete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Delete session"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/danger" />
        </LinearLayout>

        <!-- Date -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Feb 25, 2026 - 14:30"
            android:textSize="12sp"
            android:textColor="?colorOnSurfaceVariant"
            android:layout_marginBottom="10dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:listDivider"
            android:layout_marginBottom="10dp" />

        <!-- Stats row: Study Duration, Break Duration, Breaks -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Study Duration -->
            <TextView
                android:id="@+id/tvStudyDuration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Study: 45m 0s"
                android:textSize="13sp"
                android:textColor="?colorPrimary"
                android:textStyle="bold" />

            <!-- Break Duration -->
            <TextView
                android:id="@+id/tvBreakDuration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Break: 5m 0s"
                android:textSize="13sp"
                android:textColor="?colorOnSurfaceVariant"
                android:gravity="center" />

            <!-- Breaks Taken -->
            <TextView
                android:id="@+id/tvBreaks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Breaks: 2"
                android:textSize="13sp"
                android:textColor="?colorOnSurfaceVariant"
                android:gravity="end" />
        </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
